{
  "info": {
    "_postman_id": "7bb5cc4f-bd6c-4fdd-b420-9e561de0335a",
    "name": "API Testing Assignment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "54785506"
  },
  "item": [
    {
      "name": "Get Posts",
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "auth": {
          "type": "inherit"
        },
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{base_url}}/posts",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Post",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set(\"randomTitle\", \"Title_\" + Math.floor(Math.random() * 1000));\r",
              "\r",
              "pm.environment.set(\"randomBody\", \"Body_\" + Math.floor(Math.random() * 1000));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Response has an id\", function () {",
              "    pm.expect(jsonData).to.have.property(\"id\");",
              "});",
              "",
              "if (jsonData && jsonData.id !== undefined && jsonData.id !== null) {",
              "    pm.environment.set(\"post_id\", String(jsonData.id));",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"title\": \"{{randomTitle}}\",\r\n  \"body\": \"{{randomBody}}\",\r\n  \"userId\": 1\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/posts",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Single Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "auth": {
          "type": "inherit"
        },
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{base_url}}/posts/{{post_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
